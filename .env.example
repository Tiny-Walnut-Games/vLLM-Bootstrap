# vLLM-Doctrine Environment Configuration
# Copy this file to .env and customize for your environment

# ============================================================================
# Authentication & Security
# ============================================================================

# Fallback OpenAI-Compatible Server Token
# Used when vLLM fails to start or on low-memory systems
# Default: 'fallback-token-12345' (for development/testing)
# Change this in production to a secure random string
FALLBACK_AUTH_TOKEN=fallback-token-12345

# ============================================================================
# HuggingFace Configuration (Optional)
# ============================================================================

# Your HuggingFace token for accessing gated models (Llama, Gemma, etc.)
# Get it from: https://huggingface.co/settings/tokens
# Leave empty to skip HuggingFace authentication
HF_TOKEN=

# ============================================================================
# Model Configuration
# ============================================================================

# Default model tier to launch
# Options: 1B, 4B, 7B, 15B
# Default: 1B (fastest, lowest memory)
MODEL_TIER=1B

# GPU Memory Utilization
# Override automatic detection
# Range: 0.1 to 1.0 (0.5 = 50% of available VRAM)
# Leave empty for automatic detection based on available VRAM
GPU_MEMORY_UTILIZATION=

# ============================================================================
# Testing Configuration
# ============================================================================

# Test timeout (seconds) for E2E tests
TEST_TIMEOUT=180

# Test port (when running tests with specific port)
TEST_PORT=8100

# Test tier (fast, edit, qa, plan)
TEST_TIER=fast

# ============================================================================
# Deployment & Environment
# ============================================================================

# Environment: development, testing, production
ENVIRONMENT=development

# CI/CD mode (true when running in GitHub Actions)
CI=false

# ============================================================================
# Development & Debugging
# ============================================================================

# Enable verbose logging
VERBOSE=false

# Keep temporary files for debugging
DEBUG=false

# Log level: error, warn, info, debug, trace
LOG_LEVEL=info